# .env.example
# ─── Database ───────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@db.supabase.co:5432/ringit

# ─── Security ───────────────────────────────────
SECRET_KEY_B64=<base64-encoded-32-byte-AES-256-key>
JWT_PRIVATE_KEY=<RS256-private-key-PEM>
JWT_PUBLIC_KEY=<RS256-public-key-PEM>

# ─── CORS ───────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:5173","https://app.ringit.my"]

# ─── Cloudinary ─────────────────────────────────
CLOUDINARY_CLOUD_NAME=ringit-vault
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Supabase ───────────────────────────────────
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=

# ─── App ────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
